  deleter      User?         @relation("ReportDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  @@index([id_user])
  @@index([report_type])
  @@index([status])
  @@index([priority])
  @@index([id_message])
  @@index([id_conversation])
  @@index([id_project])
  @@index([deleted_at])
  @@map("reports")
}

model Notification {
  id_notification     String   @id @default(uuid()) @db.Char(36)
  title               String   @db.VarChar(255)
  message             String   @db.Text
  notification_type   String   @default("info") @db.VarChar(20)
  category            String   @default("system") @db.VarChar(30)
  sender_id           String?  @db.Char(36)
  id_project          String?  @db.Char(36)
  id_team             String?  @db.Char(36)
  id_team_role        String?  @db.Char(36)
  source_entity_type  String?  @db.VarChar(100)
  source_entity_id    String?  @db.Char(36)
  action_url          String?  @db.Text
  action_label        String?  @db.VarChar(100)
  icon                String?  @db.VarChar(100)
  is_global           Boolean  @default(false)
  created_at          DateTime @default(now())
  created_by          String?  @db.Char(36)
  updated_at          DateTime @default(now()) @updatedAt
  updated_by          String?  @db.Char(36)
  deleted_at          DateTime?
  deleted_by          String?  @db.Char(36)
  sender    User?     @relation("NotificationSender", fields: [sender_id], references: [id_user], onDelete: SetNull)
  project   Project?  @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  team      Team?     @relation(fields: [id_team], references: [id_team], onDelete: SetNull)
  team_role TeamRole? @relation(fields: [id_team_role], references: [id_team_role], onDelete: SetNull)
  creator   User? @relation("NotificationCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater   User? @relation("NotificationUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter   User? @relation("NotificationDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  recipients NotificationRecipient[]
  @@index([id_project])
  @@index([id_team])
  @@index([id_team_role])
  @@index([sender_id])
  @@index([notification_type])
  @@index([category])
  @@index([created_at])
  @@index([is_global])
  @@index([deleted_at])
  @@map("notifications")
}

model NotificationRecipient {
  id_notification_recipient String   @id @default(uuid()) @db.Char(36)
  id_notification           String   @db.Char(36)
  id_user                   String   @db.Char(36)
  delivery_status           String   @default("pending") @db.VarChar(20)
  is_read                   Boolean  @default(false)
  sent_at                   DateTime?
  delivered_at              DateTime?
  read_at                   DateTime?
  failure_reason            String?  @db.Text
  created_at                DateTime @default(now())
  updated_at                DateTime @default(now()) @updatedAt
  notification Notification @relation(fields: [id_notification], references: [id_notification], onDelete: Cascade)
  user         User         @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  @@unique([id_notification, id_user], name: "uq_notification_recipient")
  @@index([id_user])
  @@index([id_notification])
  @@index([is_read])
  @@index([delivery_status])
  @@map("notification_recipients")
}

model NotificationGroup {
  id_group_notification String   @id @default(uuid()) @db.Char(36)
  group_name            String   @db.VarChar(150)
  description           String?  @db.Text
  id_team               String?  @db.Char(36)
  id_project            String?  @db.Char(36)
  created_at            DateTime @default(now())
  created_by            String?  @db.Char(36)
  updated_at            DateTime @default(now()) @updatedAt
  updated_by            String?  @db.Char(36)
  deleted_at            DateTime?
  deleted_by            String?  @db.Char(36)
  team    Team?    @relation(fields: [id_team], references: [id_team], onDelete: SetNull)
  project Project? @relation(fields: [id_project], references: [id_project], onDelete: SetNull)
  creator User? @relation("NgCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("NgUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("NgDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  members NotificationGroupMember[]
  @@index([id_team])
  @@index([id_project])
  @@index([deleted_at])
  @@map("notification_groups")
}

model NotificationGroupMember {
  id_group_notification String   @db.Char(36)
  id_user               String   @db.Char(36)
  created_at            DateTime @default(now())
  group NotificationGroup @relation(fields: [id_group_notification], references: [id_group_notification], onDelete: Cascade)
  user  User              @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  @@id([id_group_notification, id_user])
  @@index([id_user])
  @@map("notification_group_members")
}

model ActivityFeed {
  id_activity         String   @id @default(uuid()) @db.Char(36)
  id_project          String   @db.Char(36)
  id_user             String?  @db.Char(36)
  id_phase            Int?
  id_conversation     String?  @db.Char(36)
  id_message          String?  @db.Char(36)
  id_generated_table  String?  @db.Char(36)
  id_job              String?  @db.Char(36)
  id_execution        String?  @db.Char(36)
  id_file             String?  @db.Char(36)
  activity_type       String   @db.VarChar(40)
  activity_level      String   @default("info") @db.VarChar(20)
  title               String   @db.VarChar(255)
  description         String?  @db.Text
  metadata            Json?
  is_system_generated Boolean  @default(true)
  created_at          DateTime @default(now())
  project      Project         @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  user         User?           @relation(fields: [id_user], references: [id_user], onDelete: SetNull)
  phase        WorkflowPhase?  @relation(fields: [id_phase], references: [id_phase], onDelete: SetNull)
  conversation Conversation?   @relation(fields: [id_conversation], references: [id_conversation], onDelete: SetNull)
  message      Message?        @relation(fields: [id_message], references: [id_message], onDelete: SetNull)
  dataset      GeneratedTable? @relation(fields: [id_generated_table], references: [id_generated_table], onDelete: SetNull)
  job          AiJob?          @relation(fields: [id_job], references: [id_job], onDelete: SetNull)
  execution    EtlExecution?   @relation(fields: [id_execution], references: [id_execution], onDelete: SetNull)
  file         File?           @relation(fields: [id_file], references: [id_file], onDelete: SetNull)
  @@index([id_project])
  @@index([id_user])
  @@index([activity_type])
  @@index([created_at])
  @@index([id_phase])
  @@index([id_conversation])
  @@index([id_generated_table])
  @@map("activity_feed")
}

model AnalyticsReport {
  id_report          String   @id @default(uuid()) @db.Char(36)
  id_project         String   @db.Char(36)
  created_by         String   @db.Char(36)
  report_name        String   @db.VarChar(255)
  report_type        String   @db.VarChar(20)
  description        String?  @db.Text
  visibility         String   @default("team") @db.VarChar(20)
  status             String   @default("active") @db.VarChar(20)
  current_version    Int      @default(1)
  is_ai_generated    Boolean  @default(false)
  last_generated_at  DateTime?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now()) @updatedAt
  project Project @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  creator User    @relation(fields: [created_by], references: [id_user], onDelete: Cascade)
  versions AnalyticsReportVersion[]
  widgets  AnalyticsReportWidget[]
  metrics  AnalyticsReportMetric[]
  exports  AnalyticsReportExport[]
  @@index([id_project])
  @@index([created_by])
  @@index([report_type])
  @@index([visibility])
  @@index([status])
  @@map("analytics_reports")
}

model AnalyticsReportVersion {
  id_version         String   @id @default(uuid()) @db.Char(36)
  id_report          String   @db.Char(36)
  version_number     Int
  configuration_path String   @db.Text
  snapshot_path      String?  @db.Text
  changelog          String?  @db.Text
  created_by         String?  @db.Char(36)
  created_at         DateTime @default(now())
  report  AnalyticsReport @relation(fields: [id_report], references: [id_report], onDelete: Cascade)
  creator User?           @relation(fields: [created_by], references: [id_user], onDelete: SetNull)
  @@unique([id_report, version_number], name: "uq_arv_report_version")
  @@index([id_report])
  @@map("analytics_report_versions")
}

model AnalyticsReportWidget {
  id_widget      String   @id @default(uuid()) @db.Char(36)
  id_report      String   @db.Char(36)
  widget_type    String   @db.VarChar(30)
  widget_title   String?  @db.VarChar(255)
  dataset_source String?  @db.VarChar(255)
  config         Json
  position_x     Int      @default(0)
  position_y     Int      @default(0)
  width          Int      @default(4)
  height         Int      @default(4)
  created_at     DateTime @default(now())
  report AnalyticsReport @relation(fields: [id_report], references: [id_report], onDelete: Cascade)
  @@index([id_report])
  @@index([widget_type])
  @@map("analytics_report_widgets")
}

model AnalyticsReportMetric {
  id_metric        String   @id @default(uuid()) @db.Char(36)
  id_report        String   @db.Char(36)
  metric_name      String   @db.VarChar(255)
  metric_formula   String?  @db.Text
  aggregation_type String   @default("sum") @db.VarChar(20)
  format_type      String   @default("number") @db.VarChar(20)
  created_at       DateTime @default(now())
  report AnalyticsReport @relation(fields: [id_report], references: [id_report], onDelete: Cascade)
  @@index([id_report])
  @@map("analytics_report_metrics")
}

model AnalyticsReportExport {
  id_export    String   @id @default(uuid()) @db.Char(36)
  id_report    String   @db.Char(36)
  exported_by  String   @db.Char(36)
  export_type  String   @db.VarChar(20)
  storage_path String   @db.Text
  file_size    BigInt?
  created_at   DateTime @default(now())
  report   AnalyticsReport @relation(fields: [id_report], references: [id_report], onDelete: Cascade)
  exporter User            @relation(fields: [exported_by], references: [id_user], onDelete: Cascade)
  @@index([id_report])
  @@index([exported_by])
  @@index([export_type])
  @@map("analytics_report_exports")
}

model AuditLog {
  id_log      String   @id @default(uuid()) @db.Char(36)
