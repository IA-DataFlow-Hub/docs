model GeneratedTable {
  id_generated_table        String   @id @default(uuid()) @db.Char(36)
  id_project                String   @db.Char(36)
  id_conversation           String?  @db.Char(36)
  id_message                String?  @db.Char(36)
  id_user                   String?  @db.Char(36)
  id_job                    String?  @db.Char(36)
  source_file_id            String?  @db.Char(36)
  parent_generated_table_id String?  @db.Char(36)
  table_name                String   @db.VarChar(255)
  display_name              String?  @db.VarChar(255)
  description               String?  @db.Text
  storage_type              String   @default("parquet") @db.VarChar(20)
  storage_path              String   @db.Text
  preview_path              String?  @db.Text
  schema_path               String?  @db.Text
  rows_count                BigInt   @default(0)
  columns_count             Int      @default(0)
  file_size                 BigInt   @default(0)
  generation_type           String   @default("uploaded") @db.VarChar(30)
  status                    String   @default("ready") @db.VarChar(30)
  created_at                DateTime @default(now())
  updated_at                DateTime @default(now()) @updatedAt
  project      Project        @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  conversation Conversation?  @relation(fields: [id_conversation], references: [id_conversation], onDelete: SetNull)
  message      Message?       @relation(fields: [id_message], references: [id_message], onDelete: SetNull)
  user         User?          @relation(fields: [id_user], references: [id_user], onDelete: SetNull)
  job          AiJob?         @relation(fields: [id_job], references: [id_job], onDelete: SetNull)
  source_file  File?          @relation("GtSourceFile", fields: [source_file_id], references: [id_file], onDelete: SetNull)
  parent       GeneratedTable? @relation("GtParent", fields: [parent_generated_table_id], references: [id_generated_table], onDelete: SetNull)
  children     GeneratedTable[] @relation("GtParent")
  columns         GeneratedTableColumn[]
  etl_executions  EtlExecution[]   @relation("EtlInputDataset")
  etl_outputs     EtlExecution[]   @relation("EtlOutputDataset")
  activities      ActivityFeed[]
  @@index([id_project])
  @@index([id_conversation])
  @@index([id_message])
  @@index([id_user])
  @@index([id_job])
  @@index([source_file_id])
  @@index([parent_generated_table_id])
  @@index([status])
  @@index([generation_type])
  @@map("generated_tables")
}

model GeneratedTableColumn {
  id_column          String   @id @default(uuid()) @db.Char(36)
  id_generated_table String   @db.Char(36)
