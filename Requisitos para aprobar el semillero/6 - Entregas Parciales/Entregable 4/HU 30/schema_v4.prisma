  data_type          String?  @db.VarChar(100)
  is_nullable        Boolean  @default(true)
  is_primary_key     Boolean  @default(false)
  is_foreign_key     Boolean  @default(false)
  is_unique_column   Boolean  @default(false)
  default_value      String?  @db.Text
  validations        Json?
  column_order       Int      @default(0)
  created_at         DateTime @default(now())
  table GeneratedTable @relation(fields: [id_generated_table], references: [id_generated_table], onDelete: Cascade)
  @@index([id_generated_table])
  @@index([column_name])
  @@map("generated_table_columns")
}

model EtlTemplate {
  id_template            String   @id @default(uuid()) @db.Char(36)
  id_project             String?  @db.Char(36)
  created_by             String?  @db.Char(36)
  template_name          String   @db.VarChar(255)
  description            String?  @db.Text
  category               String   @default("transformation") @db.VarChar(30)
  difficulty             String   @default("easy") @db.VarChar(20)
  estimated_time_minutes Int      @default(5)
  icon                   String?  @db.VarChar(100)
  color                  String?  @db.VarChar(50)
  is_system              Boolean  @default(false)
  is_public              Boolean  @default(false)
  version                String   @default("1.0.0") @db.VarChar(20)
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now()) @updatedAt
  project Project? @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  creator User?    @relation(fields: [created_by], references: [id_user], onDelete: SetNull)
  steps      EtlTemplateStep[]
  executions EtlExecution[]
  @@index([id_project])
  @@index([created_by])
  @@index([category])
  @@index([is_system])
  @@map("etl_templates")
}

model EtlTemplateStep {
  id_step        String   @id @default(uuid()) @db.Char(36)
  id_template    String   @db.Char(36)
  step_order     Int
  step_name      String   @db.VarChar(255)
  operation_type String   @db.VarChar(30)
  configuration  Json?
  ai_enabled     Boolean  @default(false)
  created_at     DateTime @default(now())
  template EtlTemplate @relation(fields: [id_template], references: [id_template], onDelete: Cascade)
  @@index([id_template])
  @@index([id_template, step_order])
  @@map("etl_template_steps")
}

model EtlExecution {
  id_execution              String   @id @default(uuid()) @db.Char(36)
  id_template               String   @db.Char(36)
  id_project                String   @db.Char(36)
  id_generated_table        String   @db.Char(36)
  executed_by               String?  @db.Char(36)
  id_conversation           String?  @db.Char(36)
  id_message                String?  @db.Char(36)
  execution_status          String   @default("pending") @db.VarChar(20)
  started_at                DateTime?
  finished_at               DateTime?
  execution_time_ms         BigInt   @default(0)
  rows_processed            BigInt   @default(0)
  output_generated_table_id String?  @db.Char(36)
  logs_path                 String?  @db.Text
  error_message             String?  @db.Text
  created_at                DateTime @default(now())
  template       EtlTemplate    @relation(fields: [id_template], references: [id_template], onDelete: Cascade)
  project        Project        @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  input_dataset  GeneratedTable @relation("EtlInputDataset", fields: [id_generated_table], references: [id_generated_table], onDelete: Cascade)
  output_dataset GeneratedTable? @relation("EtlOutputDataset", fields: [output_generated_table_id], references: [id_generated_table], onDelete: SetNull)
  executor       User?          @relation(fields: [executed_by], references: [id_user], onDelete: SetNull)
  conversation   Conversation?  @relation(fields: [id_conversation], references: [id_conversation], onDelete: SetNull)
  message        Message?       @relation(fields: [id_message], references: [id_message], onDelete: SetNull)
  logs       EtlExecutionLog[]
  activities ActivityFeed[]
  @@index([id_template])
  @@index([id_project])
  @@index([id_generated_table])
  @@index([output_generated_table_id])
  @@index([execution_status])
  @@index([id_conversation])
  @@index([id_message])
  @@map("etl_executions")
}

model EtlExecutionLog {
  id_log       String   @id @default(uuid()) @db.Char(36)
  id_execution String   @db.Char(36)
  log_level    String   @default("info") @db.VarChar(20)
  message      String   @db.Text
  created_at   DateTime @default(now())
