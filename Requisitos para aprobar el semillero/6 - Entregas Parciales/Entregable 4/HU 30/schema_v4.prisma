  id_project  String?  @db.Char(36)
  action      String   @db.VarChar(255)
  entity_type String?  @db.VarChar(100)
  entity_id   String?  @db.Char(36)
  old_value   String?  @db.Text
  new_value   String?  @db.Text
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now())
  deleted_at  DateTime?
  deleted_by  String?  @db.Char(36)
  user    User?    @relation("AuditUser", fields: [id_user], references: [id_user], onDelete: SetNull)
  project Project? @relation(fields: [id_project], references: [id_project], onDelete: SetNull)
