// ============================================================
// IA DATAFLOW v4.0 — Prisma schema
// HU-030: PKs operativas → String UUID (CHAR(36))
//         Catálogos pequeños → Int autoincrement
// ============================================================
// NOTA: este archivo refleja exactamente ia_dataflow_v4.sql.
// Recomendación: ejecutar `prisma db pull` contra ia_dataflow_v4
// para generar este schema automáticamente y comparar.
// ============================================================

generator client { provider = "prisma-client-js" }
datasource db    { provider = "mysql"; url = env("DATABASE_URL") }

// ============================================================
// CATÁLOGOS (Int)
// ============================================================

model UserStatus {
  id_user_status Int     @id @default(autoincrement())
  status_name    String  @unique @db.VarChar(100)
  description    String? @db.Text
  is_active      Boolean @default(true)
  created_at     DateTime @default(now())
  users          User[]
  @@map("user_statuses")
}

model AiEngineType {
  id_ai_engine_type Int     @id @default(autoincrement())
  type_name         String  @unique @db.VarChar(100)
  description       String? @db.Text
  is_active         Boolean @default(true)
  created_at        DateTime @default(now())
  engines           AiEngine[]
  @@map("ai_engine_types")
}

model ProjectPrivacyLevel {
  id_project_privacy_level Int     @id @default(autoincrement())
  level_name               String  @unique @db.VarChar(100)
  description              String? @db.Text
  is_active                Boolean @default(true)
  created_at               DateTime @default(now())
  projects                 Project[]
  @@map("project_privacy_levels")
}

model ProjectStatus {
  id_project_status Int      @id @default(autoincrement())
  status_name       String   @unique @db.VarChar(100)
  description       String?  @db.Text
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  projects          Project[]
  @@map("project_statuses")
}

model ProjectPhaseStatus {
  id_project_phase_status Int      @id @default(autoincrement())
  status_name             String   @unique @db.VarChar(100)
  description             String?  @db.Text
  is_active               Boolean  @default(true)
  created_at              DateTime @default(now())
  project_phases          ProjectPhase[]
  @@map("project_phase_statuses")
}

model AiJobStatus {
  id_ai_job_status Int      @id @default(autoincrement())
  status_name      String   @unique @db.VarChar(100)
  description      String?  @db.Text
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  ai_jobs          AiJob[]
  @@map("ai_job_statuses")
}

model AiResultType {
  id_ai_result_type Int      @id @default(autoincrement())
  type_name         String   @unique @db.VarChar(100)
  description       String?  @db.Text
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  ai_results        AiResult[]
  @@map("ai_result_types")
}

model TaskStatus {
  id_task_status Int      @id @default(autoincrement())
  status_name    String   @unique @db.VarChar(100)
  description    String?  @db.Text
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  tasks          Task[]
  @@map("task_statuses")
}

model TaskPriority {
  id_task_priority Int      @id @default(autoincrement())
  priority_name    String   @unique @db.VarChar(100)
  description      String?  @db.Text
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  tasks            Task[]
  @@map("task_priorities")
}

model MessageSenderType {
  id_message_sender_type Int      @id @default(autoincrement())
  type_name              String   @unique @db.VarChar(100)
  description            String?  @db.Text
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())
  messages               Message[]
  @@map("message_sender_types")
}

model AuthMethod {
  id_auth_method Int      @id @default(autoincrement())
  method_name    String   @unique @db.VarChar(100)
  description    String?  @db.Text
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  credentials    Credential[]
  @@map("auth_methods")
}

model ConfigurationKey {
  id_config_key   Int      @id @default(autoincrement())
  key_name        String   @unique @db.VarChar(100)
  display_name    String   @db.VarChar(255)
  description     String?  @db.Text
  category        String   @db.VarChar(100)
  value_type      String   @db.VarChar(20)
  default_value   String?  @db.Text
  is_required     Boolean  @default(false)
  validation_rules Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
  user_configurations UserConfiguration[]
  @@index([category])
  @@map("configuration_keys")
}

model RoleTemplate {
  id_role_template Int      @id @default(autoincrement())
  template_name    String   @unique @db.VarChar(100)
  description      String?  @db.Text
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt
  team_roles       TeamRole[]
  permissions      RoleTemplatePermission[]
  @@map("role_templates")
}

model Permission {
  id_permission   Int      @id @default(autoincrement())
  permission_name String   @unique @db.VarChar(100)
  module_name     String?  @db.VarChar(100)
  description     String?  @db.Text
  created_at      DateTime @default(now())
  created_by      String?  @db.Char(36)
  updated_at      DateTime @default(now()) @updatedAt
  updated_by      String?  @db.Char(36)
  deleted_at      DateTime?
  deleted_by      String?  @db.Char(36)

  creator User? @relation("PermissionCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("PermissionUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("PermissionDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  role_templates       RoleTemplatePermission[]
  team_role_permissions TeamRolePermission[]
  @@map("permissions")
}

model RoleTemplatePermission {
  id_role_template_permission Int      @id @default(autoincrement())
  id_role_template            Int
  id_permission               Int
  created_at                  DateTime @default(now())
  updated_at                  DateTime @default(now()) @updatedAt
  template   RoleTemplate @relation(fields: [id_role_template], references: [id_role_template], onDelete: Cascade)
  permission Permission   @relation(fields: [id_permission], references: [id_permission], onDelete: Cascade)
  @@unique([id_role_template, id_permission], name: "uk_template_perm")
  @@map("role_template_permissions")
}

model IdentityProvider {
  id_provider   Int      @id @default(autoincrement())
  provider_name String   @unique @db.VarChar(100)
  description   String?  @db.Text
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  created_by    String?  @db.Char(36)
  updated_at    DateTime @default(now()) @updatedAt
  updated_by    String?  @db.Char(36)
  deleted_at    DateTime?
  deleted_by    String?  @db.Char(36)
  creator       User? @relation("IdpCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater       User? @relation("IdpUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter       User? @relation("IdpDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  credentials   Credential[]
  @@map("identity_providers")
}

model WorkflowPhase {
  id_phase    Int      @id @default(autoincrement())
  phase_name  String   @unique @db.VarChar(100)
  phase_order Int      @default(0) @db.TinyInt
  description String?  @db.Text
  created_at  DateTime @default(now())
  created_by  String?  @db.Char(36)
  updated_at  DateTime @default(now()) @updatedAt
  updated_by  String?  @db.Char(36)
  deleted_at  DateTime?
  deleted_by  String?  @db.Char(36)
  creator User? @relation("WfPhaseCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("WfPhaseUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("WfPhaseDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  projects        Project[]
  project_phases  ProjectPhase[]
  conversations   Conversation[]
  ai_jobs         AiJob[]
  tasks           Task[]
  activities      ActivityFeed[]
  @@map("workflow_phases")
}

model AiEngine {
  id_engine         Int      @id @default(autoincrement())
  engine_name       String   @unique @db.VarChar(100)
  id_ai_engine_type Int
  model_version     String?  @db.VarChar(100)
  description       String?  @db.Text
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  created_by        String?  @db.Char(36)
  updated_at        DateTime @default(now()) @updatedAt
  updated_by        String?  @db.Char(36)
  deleted_at        DateTime?
  deleted_by        String?  @db.Char(36)
  type     AiEngineType @relation(fields: [id_ai_engine_type], references: [id_ai_engine_type], onDelete: Restrict)
  creator  User? @relation("AiEngineCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater  User? @relation("AiEngineUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter  User? @relation("AiEngineDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  ai_jobs  AiJob[]
  messages Message[]
  @@map("ai_engines")
}

// ============================================================
// USERS (UUID raíz)
// ============================================================

model User {
  id_user         String  @id @default(uuid()) @db.Char(36)
  full_name       String  @db.VarChar(150)
  email           String  @unique @db.VarChar(150)
  phone           String? @db.VarChar(20)
  profile_picture String? @db.VarChar(255)
  id_user_status  Int     @default(1)
  created_at      DateTime @default(now())
  created_by      String?  @db.Char(36)
  updated_at      DateTime @default(now()) @updatedAt
  updated_by      String?  @db.Char(36)
  deleted_at      DateTime?
  deleted_by      String?  @db.Char(36)

  status   UserStatus @relation(fields: [id_user_status], references: [id_user_status], onDelete: Restrict)
  creator  User?  @relation("UserCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater  User?  @relation("UserUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter  User?  @relation("UserDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  created_users User[] @relation("UserCreator")
  updated_users User[] @relation("UserUpdater")
  deleted_users User[] @relation("UserDeleter")

  // Relaciones inversas (resumidas — el resto se autopopula via Prisma)
  credentials                Credential[]
  password_history           PasswordHistory[]
  user_configurations        UserConfiguration[]
  teams_created              Team[] @relation("TeamCreator")
  teams_updated              Team[] @relation("TeamUpdater")
  teams_deleted              Team[] @relation("TeamDeleter")
  user_team_roles            UserTeamRole[]
  user_project_roles         UserProjectRole[]
  projects_owned             Project[] @relation("ProjectOwner")
  projects_created           Project[] @relation("ProjectCreator")
  projects_updated           Project[] @relation("ProjectUpdater")
  projects_deleted           Project[] @relation("ProjectDeleter")
  files                      File[] @relation("FileUploader")
  files_created              File[] @relation("FileCreator")
  files_updated              File[] @relation("FileUpdater")
  files_deleted              File[] @relation("FileDeleter")
  file_versions_created      FileVersion[] @relation("FvCreator")
  file_versions_updated      FileVersion[] @relation("FvUpdater")
  file_versions_deleted      FileVersion[] @relation("FvDeleter")
  ai_jobs_requested          AiJob[] @relation("AjRequester")
  ai_jobs_created            AiJob[] @relation("AjCreator")
  ai_jobs_updated            AiJob[] @relation("AjUpdater")
  ai_jobs_deleted            AiJob[] @relation("AjDeleter")
  ai_job_events              AiJobEvent[]
  ai_results_created         AiResult[] @relation("ArCreator")
  ai_results_updated         AiResult[] @relation("ArUpdater")
  ai_results_deleted         AiResult[] @relation("ArDeleter")
  tasks_assigned             Task[] @relation("TaskAssignee")
  tasks_created              Task[] @relation("TaskCreator")
  tasks_updated              Task[] @relation("TaskUpdater")
  tasks_deleted              Task[] @relation("TaskDeleter")
  conversations_created      Conversation[] @relation("ConvCreator")
  conversations_updated      Conversation[] @relation("ConvUpdater")
  conversations_deleted      Conversation[] @relation("ConvDeleter")
  messages_sent              Message[] @relation("MessageUser")
  messages_created           Message[] @relation("MessageCreator")
  messages_updated           Message[] @relation("MessageUpdater")
  messages_deleted           Message[] @relation("MessageDeleter")
  message_feedbacks          MessageFeedback[]
  reports                    Report[] @relation("ReportUser")
  reports_updated            Report[] @relation("ReportUpdater")
  reports_deleted            Report[] @relation("ReportDeleter")
  notifications_sent         Notification[] @relation("NotificationSender")
  notifications_created      Notification[] @relation("NotificationCreator")
  notifications_updated      Notification[] @relation("NotificationUpdater")
  notifications_deleted      Notification[] @relation("NotificationDeleter")
  notification_recipients    NotificationRecipient[]
  notification_groups_created NotificationGroup[] @relation("NgCreator")
  notification_groups_updated NotificationGroup[] @relation("NgUpdater")
  notification_groups_deleted NotificationGroup[] @relation("NgDeleter")
  notification_group_members NotificationGroupMember[]
  generated_tables           GeneratedTable[]
  etl_templates              EtlTemplate[]
  etl_executions             EtlExecution[]
  activities                 ActivityFeed[]
  analytics_reports          AnalyticsReport[]
  analytics_report_versions  AnalyticsReportVersion[]
  analytics_report_exports   AnalyticsReportExport[]
  audit_logs                 AuditLog[] @relation("AuditUser")
  audit_logs_deleted         AuditLog[] @relation("AuditDeleter")
  sessions                   Session[] @relation("SessionUser")
  sessions_created           Session[] @relation("SessionCreator")
  sessions_updated           Session[] @relation("SessionUpdater")
  sessions_deleted           Session[] @relation("SessionDeleter")
  audits                     Audit[]
  permissions_created        Permission[] @relation("PermissionCreator")
  permissions_updated        Permission[] @relation("PermissionUpdater")
  permissions_deleted        Permission[] @relation("PermissionDeleter")
  idps_created               IdentityProvider[] @relation("IdpCreator")
  idps_updated               IdentityProvider[] @relation("IdpUpdater")
  idps_deleted               IdentityProvider[] @relation("IdpDeleter")
  ai_engines_created         AiEngine[] @relation("AiEngineCreator")
  ai_engines_updated         AiEngine[] @relation("AiEngineUpdater")
  ai_engines_deleted         AiEngine[] @relation("AiEngineDeleter")
  wf_phases_created          WorkflowPhase[] @relation("WfPhaseCreator")
  wf_phases_updated          WorkflowPhase[] @relation("WfPhaseUpdater")
  wf_phases_deleted          WorkflowPhase[] @relation("WfPhaseDeleter")
  pp_created                 ProjectPhase[] @relation("PpCreator")
  pp_updated                 ProjectPhase[] @relation("PpUpdater")
  pp_deleted                 ProjectPhase[] @relation("PpDeleter")
  credentials_created        Credential[] @relation("CredCreator")
  credentials_updated        Credential[] @relation("CredUpdater")
  credentials_deleted        Credential[] @relation("CredDeleter")

  @@index([id_user_status])
  @@index([deleted_at])
  @@map("users")
}

model Credential {
  id_credential        String   @id @default(uuid()) @db.Char(36)
  id_user              String   @db.Char(36)
  provider_id          Int?
  provider_user_id     String?  @db.VarChar(255)
  provider_email       String?  @db.VarChar(255)
  password_hash        String?  @db.VarChar(255)
  password_salt        String?  @db.VarChar(255)
  mfa_enabled          Boolean  @default(false)
  last_password_change DateTime?
  id_auth_method       Int      @default(1)
  created_at           DateTime @default(now())
  created_by           String?  @db.Char(36)
  updated_at           DateTime @default(now()) @updatedAt
  updated_by           String?  @db.Char(36)
  deleted_at           DateTime?
  deleted_by           String?  @db.Char(36)

  user        User              @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  provider    IdentityProvider? @relation(fields: [provider_id], references: [id_provider], onDelete: SetNull)
  auth_method AuthMethod        @relation(fields: [id_auth_method], references: [id_auth_method], onDelete: Restrict)
  creator     User? @relation("CredCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater     User? @relation("CredUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter     User? @relation("CredDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)

  @@index([id_user])
  @@index([provider_id])
  @@index([id_auth_method])
  @@map("credentials")
}

model PasswordHistory {
  id_history    String   @id @default(uuid()) @db.Char(36)
  id_user       String   @db.Char(36)
  password_hash String   @db.VarChar(255)
  created_at    DateTime @default(now())
  user User @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  @@index([id_user])
  @@map("password_history")
}

model UserConfiguration {
  id_user_config String   @id @default(uuid()) @db.Char(36)
  id_user        String   @db.Char(36)
  id_config_key  Int
  value          String   @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
  user User             @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  key  ConfigurationKey @relation(fields: [id_config_key], references: [id_config_key], onDelete: Cascade)
  @@unique([id_user, id_config_key], name: "uk_user_config")
  @@index([id_user])
  @@index([id_config_key])
  @@map("user_configurations")
}

model Team {
  id_team           String   @id @default(uuid()) @db.Char(36)
  team_name         String   @db.VarChar(150)
  description       String?  @db.Text
  group_type        String   @default("standard") @db.VarChar(50)
  is_personal_group Boolean  @default(false)
  created_at        DateTime @default(now())
  created_by        String?  @db.Char(36)
  updated_at        DateTime @default(now()) @updatedAt
  updated_by        String?  @db.Char(36)
  deleted_at        DateTime?
  deleted_by        String?  @db.Char(36)
  creator User? @relation("TeamCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("TeamUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("TeamDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  team_roles         TeamRole[]
  user_team_roles    UserTeamRole[]
  projects           Project[]
  notifications      Notification[]
  notification_groups NotificationGroup[]
  @@index([is_personal_group])
  @@map("teams")
}

model TeamRole {
  id_team_role String   @id @default(uuid()) @db.Char(36)
  id_team      String   @db.Char(36)
  role_name    String   @db.VarChar(100)
  description  String?  @db.Text
  is_default   Boolean  @default(false)
  template_id  Int?
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
  team     Team          @relation(fields: [id_team], references: [id_team], onDelete: Cascade)
  template RoleTemplate? @relation(fields: [template_id], references: [id_role_template], onDelete: SetNull)
  permissions   TeamRolePermission[]
  user_team_roles UserTeamRole[]
  user_project_roles UserProjectRole[]
  notifications Notification[]
  @@unique([id_team, role_name], name: "uk_team_role")
  @@index([id_team])
  @@index([template_id])
  @@map("team_roles")
}

model TeamRolePermission {
  id_team_role_permission String   @id @default(uuid()) @db.Char(36)
  id_team_role            String   @db.Char(36)
  id_permission           Int
  created_at              DateTime @default(now())
  updated_at              DateTime @default(now()) @updatedAt
  team_role  TeamRole   @relation(fields: [id_team_role], references: [id_team_role], onDelete: Cascade)
  permission Permission @relation(fields: [id_permission], references: [id_permission], onDelete: Cascade)
  @@unique([id_team_role, id_permission], name: "uk_team_role_perm")
  @@index([id_team_role])
  @@index([id_permission])
  @@map("team_role_permissions")
}

model UserTeamRole {
  id_user_team_role String   @id @default(uuid()) @db.Char(36)
  id_user           String   @db.Char(36)
  id_team           String   @db.Char(36)
  id_team_role      String   @db.Char(36)
  assigned_at       DateTime @default(now())
  user      User     @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  team      Team     @relation(fields: [id_team], references: [id_team], onDelete: Cascade)
  team_role TeamRole @relation(fields: [id_team_role], references: [id_team_role], onDelete: Cascade)
  @@unique([id_user, id_team, id_team_role], name: "uk_user_team_role")
  @@index([id_user])
  @@index([id_team])
  @@map("user_team_roles")
}

model Project {
  id_project               String   @id @default(uuid()) @db.Char(36)
  id_team                  String?  @db.Char(36)
  project_name             String   @db.VarChar(255)
  description              String?  @db.Text
  current_phase            Int?
  owner_user_id            String?  @db.Char(36)
  id_project_privacy_level Int      @default(2)
  id_project_status        Int      @default(1)
  status_changed_at        DateTime?
  created_at               DateTime @default(now())
  created_by               String   @db.Char(36)
  updated_at               DateTime @default(now()) @updatedAt
  updated_by               String?  @db.Char(36)
  deleted_at               DateTime?
  deleted_by               String?  @db.Char(36)
  team           Team?               @relation(fields: [id_team], references: [id_team], onDelete: SetNull)
  current_phase_obj WorkflowPhase?   @relation(fields: [current_phase], references: [id_phase], onDelete: SetNull)
  owner          User?               @relation("ProjectOwner", fields: [owner_user_id], references: [id_user], onDelete: SetNull)
  privacy        ProjectPrivacyLevel @relation(fields: [id_project_privacy_level], references: [id_project_privacy_level], onDelete: Restrict)
  status         ProjectStatus       @relation(fields: [id_project_status], references: [id_project_status], onDelete: Restrict)
  creator        User                @relation("ProjectCreator", fields: [created_by], references: [id_user], onDelete: Cascade)
  updater        User?               @relation("ProjectUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter        User?               @relation("ProjectDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  project_phases     ProjectPhase[]
  user_project_roles UserProjectRole[]
  files              File[]
  ai_jobs            AiJob[]
  tasks              Task[]
  conversations      Conversation[]
  generated_tables   GeneratedTable[]
  etl_templates      EtlTemplate[]
  etl_executions     EtlExecution[]
  activities         ActivityFeed[]
  analytics_reports  AnalyticsReport[]
  reports            Report[]
  notifications      Notification[]
  notification_groups NotificationGroup[]
  audit_logs         AuditLog[]
  @@index([created_by])
  @@index([owner_user_id])
  @@index([id_team])
  @@index([id_project_status])
  @@index([id_project_privacy_level])
  @@index([deleted_at])
  @@map("projects")
}

model UserProjectRole {
  id_user_project_role String   @id @default(uuid()) @db.Char(36)
  id_user              String   @db.Char(36)
  id_project           String   @db.Char(36)
  id_team_role         String   @db.Char(36)
  assigned_at          DateTime @default(now())
  user      User     @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  project   Project  @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  team_role TeamRole @relation(fields: [id_team_role], references: [id_team_role], onDelete: Cascade)
  @@unique([id_user, id_project], name: "uk_user_project_role")
  @@index([id_user])
  @@index([id_project])
  @@map("user_project_roles")
}

model ProjectPhase {
  id_project_phase        String   @id @default(uuid()) @db.Char(36)
  id_project              String   @db.Char(36)
  id_phase                Int
  id_project_phase_status Int      @default(1)
  status_changed_at       DateTime?
  started_at              DateTime @default(now())
  completed_at            DateTime?
  notes                   String?  @db.Text
  created_at              DateTime @default(now())
  created_by              String?  @db.Char(36)
  updated_at              DateTime @default(now()) @updatedAt
  updated_by              String?  @db.Char(36)
  deleted_at              DateTime?
  deleted_by              String?  @db.Char(36)
  project Project            @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  phase   WorkflowPhase      @relation(fields: [id_phase], references: [id_phase], onDelete: Cascade)
  status  ProjectPhaseStatus @relation(fields: [id_project_phase_status], references: [id_project_phase_status], onDelete: Restrict)
  creator User? @relation("PpCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("PpUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("PpDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  @@index([id_project])
  @@index([id_project_phase_status])
  @@map("project_phases")
}

model Conversation {
  id_conversation String   @id @default(uuid()) @db.Char(36)
  id_project      String   @db.Char(36)
  id_phase        Int?
  created_by      String?  @db.Char(36)
  title           String?  @db.VarChar(255)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
  updated_by      String?  @db.Char(36)
  deleted_at      DateTime?
  deleted_by      String?  @db.Char(36)
  project Project        @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  phase   WorkflowPhase? @relation(fields: [id_phase], references: [id_phase], onDelete: SetNull)
  creator User? @relation("ConvCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("ConvUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("ConvDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  messages         Message[]
  files            File[]
  ai_jobs          AiJob[]
  generated_tables GeneratedTable[]
  etl_executions   EtlExecution[]
  activities       ActivityFeed[]
  reports          Report[]
  @@index([id_project])
  @@index([deleted_at])
  @@map("conversations")
}

model Message {
  id_message              String   @id @default(uuid()) @db.Char(36)
  id_conversation         String   @db.Char(36)
  id_user                 String?  @db.Char(36)
  id_engine               Int?
  id_message_sender_type  Int      @default(1)
  message                 String   @db.Text
  sent_at                 DateTime @default(now())
  created_by              String?  @db.Char(36)
  updated_at              DateTime @default(now()) @updatedAt
  updated_by              String?  @db.Char(36)
  deleted_at              DateTime?
  deleted_by              String?  @db.Char(36)
  conversation Conversation       @relation(fields: [id_conversation], references: [id_conversation], onDelete: Cascade)
  user         User?              @relation("MessageUser", fields: [id_user], references: [id_user], onDelete: SetNull)
  engine       AiEngine?          @relation(fields: [id_engine], references: [id_engine], onDelete: SetNull)
  sender_type  MessageSenderType  @relation(fields: [id_message_sender_type], references: [id_message_sender_type], onDelete: Restrict)
  creator User? @relation("MessageCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("MessageUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("MessageDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  files            File[]
  ai_jobs          AiJob[]
  generated_tables GeneratedTable[]
  etl_executions   EtlExecution[]
  activities       ActivityFeed[]
  feedbacks        MessageFeedback[]
  reports          Report[]
  @@index([id_conversation])
  @@index([id_message_sender_type])
  @@index([deleted_at])
  @@map("messages")
}

model File {
  id_file         String   @id @default(uuid()) @db.Char(36)
  id_project      String   @db.Char(36)
  id_user         String?  @db.Char(36)
  id_conversation String?  @db.Char(36)
  id_message      String?  @db.Char(36)
  file_name       String   @db.VarChar(255)
  original_name   String?  @db.VarChar(255)
  file_type       String?  @db.VarChar(100)
  file_size       BigInt?
  storage_path    String?  @db.Text
  uploaded_at     DateTime @default(now())
  created_by      String?  @db.Char(36)
  updated_at      DateTime @default(now()) @updatedAt
  updated_by      String?  @db.Char(36)
  deleted_at      DateTime?
  deleted_by      String?  @db.Char(36)
  project      Project       @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  uploader     User?         @relation("FileUploader", fields: [id_user], references: [id_user], onDelete: SetNull)
  conversation Conversation? @relation(fields: [id_conversation], references: [id_conversation], onDelete: SetNull)
  message      Message?      @relation(fields: [id_message], references: [id_message], onDelete: SetNull)
  creator User? @relation("FileCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("FileUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("FileDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  versions         FileVersion[]
  ai_jobs          AiJob[]
  generated_tables GeneratedTable[] @relation("GtSourceFile")
  activities       ActivityFeed[]
  @@index([id_project])
  @@index([id_user])
  @@index([id_conversation])
  @@index([id_message])
  @@index([deleted_at])
  @@map("files")
}

model FileVersion {
  id_version          String   @id @default(uuid()) @db.Char(36)
  id_file             String   @db.Char(36)
  version_number      Int
  storage_path        String?  @db.Text
  changes_description String?  @db.Text
  created_by          String?  @db.Char(36)
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt
  updated_by          String?  @db.Char(36)
  deleted_at          DateTime?
  deleted_by          String?  @db.Char(36)
  file    File  @relation(fields: [id_file], references: [id_file], onDelete: Cascade)
  creator User? @relation("FvCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("FvUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("FvDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  @@unique([id_file, version_number], name: "uq_file_versions")
  @@map("file_versions")
}

model Task {
  id_task           String   @id @default(uuid()) @db.Char(36)
  id_project        String   @db.Char(36)
  id_phase          Int?
  assigned_to       String?  @db.Char(36)
  created_by        String?  @db.Char(36)
  title             String   @db.VarChar(255)
  description       String?  @db.Text
  id_task_status    Int      @default(1)
  id_task_priority  Int      @default(2)
  status_changed_at DateTime?
  due_date          DateTime? @db.Date
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt
  updated_by        String?  @db.Char(36)
  deleted_at        DateTime?
  deleted_by        String?  @db.Char(36)
  project    Project        @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  phase      WorkflowPhase? @relation(fields: [id_phase], references: [id_phase], onDelete: SetNull)
  assignee   User?          @relation("TaskAssignee", fields: [assigned_to], references: [id_user], onDelete: SetNull)
  creator    User?          @relation("TaskCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  status     TaskStatus     @relation(fields: [id_task_status], references: [id_task_status], onDelete: Restrict)
  priority   TaskPriority   @relation(fields: [id_task_priority], references: [id_task_priority], onDelete: Restrict)
  updater    User?          @relation("TaskUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter    User?          @relation("TaskDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  ai_jobs AiJob[]
  @@index([id_project])
  @@index([id_task_status])
  @@index([id_task_priority])
  @@index([deleted_at])
  @@map("tasks")
}

model AiJob {
  id_job                 String   @id @default(uuid()) @db.Char(36)
  id_project             String   @db.Char(36)
  id_file                String?  @db.Char(36)
  id_engine              Int
  id_phase               Int?
  requested_by           String?  @db.Char(36)
  job_type               String   @db.VarChar(100)
  prompt_text            String?  @db.Text
  prompt_metadata        Json?
  input_data_reference   String?  @db.Text
  is_private             Boolean  @default(false)
  created_from           String?  @db.VarChar(100)
  id_ai_job_status       Int      @default(1)
  status_changed_at      DateTime?
  queued_at              DateTime?
  started_at             DateTime?
  processing_at          DateTime?
  finished_at            DateTime?
  failed_at              DateTime?
  cancelled_at           DateTime?
  requeued_at            DateTime?
  updated_source         String?  @db.VarChar(100)
  tokens_prompt          Int      @default(0)
  tokens_completion      Int      @default(0)
  tokens_total           Int?
  processing_time_ms     Int      @default(0)
  elapsed_time_ms        Int      @default(0)
  cost_estimated         Decimal? @db.Decimal(12,6)
  cost_actual            Decimal? @db.Decimal(12,6)
  provider_request_id    String?  @db.VarChar(255)
  model_version_snapshot String?  @db.VarChar(100)
  model_info             Json?
  id_conversation        String?  @db.Char(36)
  id_message             String?  @db.Char(36)
  id_task                String?  @db.Char(36)
  error_message          String?  @db.Text
  error_stack            String?  @db.Text
  error_context          Json?
  retries_attempted      Int      @default(0)
  max_retries            Int      @default(3)
  next_retry_at          DateTime?
  final_error_code       String?  @db.VarChar(100)
  worker_id              String?  @db.VarChar(100)
  queue_name             String?  @db.VarChar(100)
  created_at             DateTime @default(now())
  created_by             String?  @db.Char(36)
  updated_at             DateTime @default(now()) @updatedAt
  updated_by             String?  @db.Char(36)
  deleted_at             DateTime?
  deleted_by             String?  @db.Char(36)
  project      Project        @relation(fields: [id_project], references: [id_project], onDelete: Cascade)
  file         File?          @relation(fields: [id_file], references: [id_file], onDelete: SetNull)
  engine       AiEngine       @relation(fields: [id_engine], references: [id_engine], onDelete: Restrict)
  phase        WorkflowPhase? @relation(fields: [id_phase], references: [id_phase], onDelete: SetNull)
  requester    User?          @relation("AjRequester", fields: [requested_by], references: [id_user], onDelete: SetNull)
  status       AiJobStatus    @relation(fields: [id_ai_job_status], references: [id_ai_job_status], onDelete: Restrict)
  conversation Conversation?  @relation(fields: [id_conversation], references: [id_conversation], onDelete: SetNull)
  message      Message?       @relation(fields: [id_message], references: [id_message], onDelete: SetNull)
  task         Task?          @relation(fields: [id_task], references: [id_task], onDelete: SetNull)
  creator      User?          @relation("AjCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater      User?          @relation("AjUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter      User?          @relation("AjDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  events           AiJobEvent[]
  results          AiResult[]
  generated_tables GeneratedTable[]
  activities       ActivityFeed[]
  @@index([id_project])
  @@index([id_engine])
  @@index([id_ai_job_status])
  @@index([id_conversation])
  @@index([id_message])
  @@index([id_task])
  @@index([queue_name])
  @@index([worker_id])
  @@index([final_error_code])
  @@index([deleted_at])
  @@map("ai_jobs")
}

model AiJobEvent {
  id_job_event  String   @id @default(uuid()) @db.Char(36)
