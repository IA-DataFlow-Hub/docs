model Session {
  id_session               String   @id @default(uuid()) @db.Char(36)
  id_user                  String   @db.Char(36)
  session_token            String   @unique @db.VarChar(255)
  refresh_token            String?  @db.VarChar(255)
  ip_address               String?  @db.VarChar(45)
  user_agent               String?  @db.Text
  browser_name             String?  @db.VarChar(100)
  browser_version          String?  @db.VarChar(50)
  operating_system         String?  @db.VarChar(100)
  operating_system_version String?  @db.VarChar(50)
  device_type              String   @default("unknown") @db.VarChar(20)
  device_name              String?  @db.VarChar(150)
  country                  String?  @db.VarChar(100)
  city                     String?  @db.VarChar(100)
  is_current               Boolean  @default(false)
  status                   String   @default("active") @db.VarChar(20)
  login_at                 DateTime @default(now())
  last_activity_at         DateTime @default(now())
  last_action              String?  @db.VarChar(255)
  heartbeat_at             DateTime?
  created_at               DateTime @default(now())
  created_by               String?  @db.Char(36)
  updated_at               DateTime @default(now()) @updatedAt
  updated_by               String?  @db.Char(36)
  expires_at               DateTime?
  revoked_at               DateTime?
  revoke_reason            String?  @db.VarChar(255)
  deleted_at               DateTime?
  deleted_by               String?  @db.Char(36)
  user    User  @relation("SessionUser", fields: [id_user], references: [id_user], onDelete: Cascade)
  creator User? @relation("SessionCreator", fields: [created_by], references: [id_user], onDelete: SetNull)
  updater User? @relation("SessionUpdater", fields: [updated_by], references: [id_user], onDelete: SetNull)
  deleter User? @relation("SessionDeleter", fields: [deleted_by], references: [id_user], onDelete: SetNull)
  @@index([id_user])
  @@index([status])
  @@index([last_activity_at])
  @@index([refresh_token])
  @@index([device_type])
  @@index([revoked_at])
  @@index([deleted_at])
  @@map("sessions")
}

model Audit {
  id_audit    String   @id @default(uuid()) @db.Char(36)
  table_id    String   @db.Char(36)
  table_name  String   @db.VarChar(255)
  action      String   @db.VarChar(255)
  data_old    Json?
  data_new    Json?
  user_id     String?  @db.Char(36)
  deleted_at  DateTime?
  reverted    Boolean  @default(false)
  reverted_at DateTime?
  created_at  DateTime @default(now())
  user User? @relation(fields: [user_id], references: [id_user], onDelete: SetNull)
  @@index([action])
  @@index([table_name])
  @@index([user_id])
  @@map("audits")
}
